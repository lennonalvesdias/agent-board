# ══════════════════════════════════════════════════════════════════════
#  AgentBoard v2 — Variáveis de Ambiente
#  Copie para .env e preencha. NUNCA suba o .env para o repositório.
# ══════════════════════════════════════════════════════════════════════

# ── Azure DevOps ──────────────────────────────────────────────────────
ADO_ORG=minha-empresa
ADO_PROJECT=meu-projeto

# PAT com permissões: Work Items (Read & Write) + Code (Read)
# Gere em: https://dev.azure.com/{org}/_usersSettings/tokens
ADO_PAT=cole_seu_pat_aqui

# ── OpenCode ──────────────────────────────────────────────────────────
# Porta do opencode serve (padrão oficial: 4096)
OPENCODE_PORT=4096

# Modelo padrão (sobrescrito por agente no opencode.json se quiser)
OPENCODE_MODEL=github/copilot

# ── Anthropic (opcional) ──────────────────────────────────────────────
# Usado para resolver perguntas do agente sobre decisões de código.
# Se não informado, o Orchestrator usa um fallback sem LLM.
ANTHROPIC_API_KEY=

# ── Orchestrator ──────────────────────────────────────────────────────
# Intervalo de polling em ms (300000 = 5 minutos)
POLLING_INTERVAL_MS=300000

# Timeout máximo por execução de agente em ms (1800000 = 30 minutos)
AGENT_TIMEOUT_MS=1800000

# TTL dos locks de PBI em minutos
LOCK_TTL_MINUTES=30

# Raiz dos repositórios clonados na sua máquina
# Mac/Linux : /Users/seu-usuario/repos
# Windows   : C:\Users\seu-usuario\repos
WORKSPACE_ROOT=/Users/seu-usuario/repos

# ── Notificações Teams ────────────────────────────────────────────────
# Deixe vazio para desabilitar.
# Como criar: Teams → canal → "..." → Conectores → Incoming Webhook
TEAMS_WEBHOOK_URL=
